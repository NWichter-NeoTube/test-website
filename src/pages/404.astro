---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Seite nicht gefunden | Test Website" description="Die angeforderte Seite wurde nicht gefunden.">
  <main class="page">
    <h1>404</h1>
    <p>Die angeforderte Seite wurde leider nicht gefunden.</p>
    <a href="/">Zurueck zur Startseite</a>
  </main>
</BaseLayout>

<style>
  .page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 6rem 1.5rem;
    text-align: center;
  }

  h1 {
    font-size: 4rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  p {
    margin-bottom: 2rem;
    color: #475569;
  }

  @media (prefers-color-scheme: dark) {
    p {
      color: #94a3b8;
    }
  }
</style>
